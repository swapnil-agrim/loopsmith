{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/sdlc_gate.sh\"",
            "statusMessage": "Applying goal-based SDLC policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/research_capture.py\"",
            "statusMessage": "Capturing research to the knowledge graph"
          }
        ]
      }
    ]
  }
}
